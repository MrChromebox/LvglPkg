#langdef en-US "English"

#string STR_FORM_SET_TITLE       #language en-US  "Graphical UI Configuration"
#string STR_FORM_SET_TITLE_HELP  #language en-US  "Configure the graphical setup UI."

#string STR_UI_SCALE_SECTION     #language en-US  "Display Scale"
#string STR_UI_SCALE_PROMPT      #language en-US  "UI Scale"
#string STR_UI_SCALE_HELP        #language en-US  "Scale factor for the graphical setup UI. Larger values make text and controls physically bigger on high-resolution displays. A reboot is required for a change to take effect."

#string STR_UI_SCALE_1X          #language en-US  "1x (native)"
#string STR_UI_SCALE_1_5X        #language en-US  "1.5x"
#string STR_UI_SCALE_2X          #language en-US  "2x"

#string STR_CENTERED_FRAME_SECTION        #language en-US  "Layout"
#string STR_CENTERED_FRAME_PROMPT         #language en-US  "Centered Aspect-Ratio Frame"
#string STR_CENTERED_FRAME_HELP         #language en-US  "When enabled, the UI is shown in a centered window with a fixed aspect ratio instead of filling the display edge-to-edge. Useful on ultrawide panels. A reboot is required for a change to take effect."

#string STR_CENTERED_FRAME_HEIGHT_PROMPT  #language en-US  "Frame Height (%)"
#string STR_CENTERED_FRAME_HEIGHT_HELP    #language en-US  "Frame height as a percentage of the display height (1-100)."

#string STR_CENTERED_FRAME_ASPECT_NUM_PROMPT  #language en-US  "Frame Aspect Width"
#string STR_CENTERED_FRAME_ASPECT_NUM_HELP    #language en-US  "Aspect-ratio numerator. Frame width = height * width / height divisor (for example 16:9)."

#string STR_CENTERED_FRAME_ASPECT_DEN_PROMPT  #language en-US  "Frame Aspect Height"
#string STR_CENTERED_FRAME_ASPECT_DEN_HELP    #language en-US  "Aspect-ratio denominator. Frame width = height * width / height divisor (for example 16:9)."
